# Copy to ~/.env.erum_staging (never commit secrets).
ERUM_ENV=staging
ERUM_API_BASE=https://<portal-preview>.vercel.app
ERUM_API_KEY=
DB_HOST=<vultr-managed-staging-host>
DB_PORT=16751
DB_USER=erum_staging
DB_PASSWORD=
DB_NAME=erum_company_staging
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=erum-news-images
R2_PUBLIC_URL=https://pub-....r2.dev
R2_KEY_PREFIX=staging/vnext
PUBLISH_STATUS=DRAFT
HIDDEN_PUBLISH_TEST=1
# Do not set GSC_SERVICE_ACCOUNT_JSON in staging.
