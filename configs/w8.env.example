# W8 operational env file template (copy to host path; chmod 600; owner = cron user).
# Example path: /root/erum-news-engine-w8/.env.w8
#
# Required exact values for W8 initial runner (any other value → fail-closed):
PUBLISH_STATUS=DRAFT
REVIEW_ONLY=0
HIDDEN_PUBLISH_TEST=0
PER_RUN_LIMIT=3
DAILY_PUBLISH_LIMIT=9
PER_SITE_PER_RUN_LIMIT=1
ONE_SOURCE_ONE_SITE=1
REVALIDATE_FAILURE_WEBHOOK_CONFIGURED=1

# Additional secrets/hosts required by engine (fill on host; never commit real secrets):
# ERUM_ENV=production
# ERUM_API_BASE=https://erum-one.com
# ERUM_API_KEY=
# DB_HOST=
# DB_PORT=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# UPSTAGE_API_KEY=   # or GEMINI_/OPENROUTER_
