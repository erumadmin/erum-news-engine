# W8 operational env file template (copy to host path; chmod 600; owner = cron user).
# Example path: /root/erum-news-engine-w8/.env.w8
#
# Loaded ONLY by Python (scripts/w8_run_engine.py). Never sourced by bash.
# ERUM_EXPLICIT_ENV_ONLY=1 is set by the runner — engine.py will not read cwd .env
# or ~/.env.erum_infra. Missing keys are NOT supplemented from other files.
#
# Required exact values (any other value → fail-closed):
PUBLISH_STATUS=DRAFT
REVIEW_ONLY=0
HIDDEN_PUBLISH_TEST=0
PER_RUN_LIMIT=3
DAILY_PUBLISH_LIMIT=9
PER_SITE_PER_RUN_LIMIT=1
ONE_SOURCE_ONE_SITE=1
ERUM_ENV=production
ERUM_API_BASE=https://erum-one.com
REVALIDATE_FAILURE_WEBHOOK_CONFIGURED=1

# Required secrets/hosts (fill on host; never commit real secrets).
# Staging/preview/empty values → fail-closed.
# ERUM_API_KEY=
# (or ADMIN_API_KEY=)
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# LLM_PROVIDER=upstage
# UPSTAGE_API_KEY=
# (or GEMINI_API_KEY / OPENROUTER_API_KEY matching provider)
